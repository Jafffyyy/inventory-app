pipeline {
    agent any

    environment {
        AWS_REGION = "us-east-1"

        BACKEND_ECR = "320542636300.dkr.ecr.us-east-1.amazonaws.com/backend-repo"
        FRONTEND_ECR = "320542636300.dkr.ecr.us-east-1.amazonaws.com/frontend-repo"

        CLUSTER = "app-cluster"
        BACKEND_SERVICE = "backend-service"
        FRONTEND_SERVICE = "frontend-service"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Images') {
            steps {
                sh 'docker build -t backend ./backend'
                sh 'docker build -t frontend ./frontend'

                sh 'docker tag backend:latest $BACKEND_ECR:latest'
                sh 'docker tag frontend:latest $FRONTEND_ECR:latest'
            }
        }

        stage('Login to ECR') {
            steps {
                sh '''
                aws ecr get-login-password --region $AWS_REGION \
                | docker login --username AWS --password-stdin 320542636300.dkr.ecr.us-east-1.amazonaws.com
                '''
            }
        }

        stage('Push to ECR') {
            steps {
                sh 'docker push $BACKEND_ECR:latest'
                sh 'docker push $FRONTEND_ECR:latest'
            }
        }

        stage('Deploy to ECS') {
            steps {
                sh '''
                aws ecs update-service \
                  --cluster "$CLUSTER" \
                  --service "$BACKEND_SERVICE" \
                  --force-new-deployment

                aws ecs update-service \
                  --cluster "$CLUSTER" \
                  --service "$FRONTEND_SERVICE" \
                  --force-new-deployment
                '''
            }
        }
    }
}
